# LLM provider: "gemini" (default) or "local" (Ollama)
LLM_PROVIDER=gemini

# Required when LLM_PROVIDER=gemini — get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_key_here

# Optional: override the model for the selected provider
# LLM_MODEL=gemini-2.0-flash

# Second cloud fallback after Gemini (chain: Gemini → ChatGPT → local Ollama)
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Optional overrides (defaults work with docker compose)
REDIS_URL=redis://redis:6379/0
CHROMA_HOST=chroma
CHROMA_PORT=8000
DATABASE_URL=sqlite:////data/researchpulse.db
